# MEDCORE example environment variables
# Copy to `.env` and fill required values for local development

# Node / app
NODE_ENV=development
PORT=3000

# Redis (fallback to in-memory is implemented when Redis is unavailable)
REDIS_URL=redis://redis:6379

# Supabase - required by backend; use placeholder values for local dev if you don't have a project
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=service-role-key-placeholder

# Session and security
SESSION_SECRET=change-me-to-a-secure-value

# Frontend (Vite)
VITE_API_BASE_URL=http://localhost:3000
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# ============================================================================
# MEDICORE SECURITY CONFIGURATION
# ============================================================================
# ⚠️  NEVER commit .env file with real credentials!
# ⚠️  NEVER copy secrets into this file - use secure vaults/CI/CD secrets
# ============================================================================

# ============================================================================
# FRONTEND ENVIRONMENT (Safe to expose - Vite public keys only)
# ============================================================================
# Supabase: Anonymous key for browser clients
# Source: Supabase Dashboard > Project Settings > API
# Safe: Yes (restricted by RLS policies)
VITE_SUPABASE_PROJECT_ID=wjeaagnlqgftzokjnbsz
VITE_SUPABASE_URL=https://your-supabase-url.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Optional backward-compatibility key name:
# VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Firebase: Public configuration (from firebase.json)
# Source: Firebase Console > Project Settings
# Safe: Yes (secured by Firebase security rules)
VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef...
VITE_FIREBASE_MEASUREMENT_ID=G-...

# Backend API URL for OTP and auth endpoints
# Used by frontend for server-side OTP verification
# Development: http://localhost:3000
# Production: https://api.medicore.com
VITE_BACKEND_URL=http://localhost:3000

# ============================================================================
# BACKEND ENVIRONMENT (Secrets - NEVER expose)
# ============================================================================
# Supabase Service Role Key (SERVER ONLY)
# ⚠️  CRITICAL: Keep this SECRET! Only use in Node.js backend, never in browser
# Store in: CI/CD secrets, .env (local only), secure vault
SUPABASE_URL=https://your-supabase-url.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJvbGUiOiJzZXJ2aWNlX3JvbGUiLCJpYXQiOjE2ODAwMDAwMDAsImV4cCI6OTk5OTk5OTk5OX0...

# ============================================================================
# CORS CONFIGURATION
# ============================================================================
# Comma-separated list of allowed origins
# ⚠️  NO WILDCARDS in production (*)
# Examples:
#   Development: http://localhost:5173,http://localhost:3000
#   Production: https://app.medicore.com,https://www.medicore.com
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================
# Auth redirect URL (after email verification, password reset, etc.)
AUTH_REDIRECT_URL=https://your-production-domain.com/auth/callback

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
# Node.js server port
PORT=3000

# Environment: development, staging, production
NODE_ENV=development
